@define-color base     #1e1e2e;
@define-color mantle   #181825;
@define-color crust    #11111b;
@define-color surface0 #313244;
@define-color surface1 #45475a;
@define-color overlay0 #6c7086;
@define-color text     #cdd6f4;
@define-color subtext0 #a6adc8;
@define-color blue     #89b4fa;
@define-color mauve    #cba6f7;
@define-color red      #f38ba8;
@define-color green    #a6e3a1;
@define-color yellow   #f9e2af;
@define-color peach    #fab387;

* {
    font-family: "MonaspiceAr Nerd Font", monospace;
    font-size: 12px;
}

window#waybar {
    background: alpha(@base, 1.00);
    border-radius: 0px;
    border: none;
    color: @text;
}

.modules-left,
.modules-center,
.modules-right {
    background: transparent;
    border-radius: 0;
    padding: 2px 8px;
    border: none;
    min-height: 0;
}

.modules-right {
    padding-right: 18px;
}

/* Arch icon */
#custom-arch {
    color: @blue;
    padding: 0 10px 0 15px;
}

/* Workspaces */
#workspaces {
    background: transparent;
}

#workspaces button {
    border-radius: 5px;
    padding: 0px 4px;
    min-width: 35px;
    background: transparent;
    color: @subtext0;
    border: none;
}

#workspaces button:hover {
    background: @surface0;
    color: @text;
}

#workspaces button.active {
    background: @blue;
    color: @base;
    animation: ws-active 3s ease infinite;
}

#workspaces button.urgent {
    background: @red;
    color: @base;
}

@keyframes ws-active {
    0%  { background-color: #89b4fa; }
    50% { background-color: #cba6f7; }
    100%{ background-color: #abd290; }
}

/* Window title */
#window {
    color: @subtext0;
    font-style: italic;
}

/* Clock */
#clock {
    color: @blue;
    font-weight: bold;
}

/* System modules */
#cpu {
    color: @peach;
}

#memory {
    color: @mauve;
}

#battery {
    color: @green;
}

#battery.warning {
    color: @yellow;
}

#battery.critical {
    color: @red;
}

#battery.charging {
    color: @green;
}

#network {
    color: @green;
}

#network.disconnected {
    color: @red;
}

#pulseaudio {
    color: @blue;
}

#pulseaudio.muted {
    color: @overlay0;
}

/* Tray */
#tray {
    color: @subtext0;
}

/* Custom modules */
#custom-weather {
    color: @peach;
}

#custom-updates {
    color: @green;
}

#custom-updates.pending {
    color: @yellow;
}

#custom-swaync {
    color: @text;
}

#custom-power {
    color: @red;
}

#custom-settings {
    color: @subtext0;
}

/* Tooltip */
tooltip {
    background: @surface0;
    border: 1px solid @overlay0;
    border-radius: 8px;
    color: @text;
}

tooltip label {
    color: @text;
}

